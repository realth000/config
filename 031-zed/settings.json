// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
    "cli_default_open_behavior": "existing_window",
    "buffer_font_weight": 400.0,
    "buffer_line_height": "comfortable",
    "buffer_font_family": "Iosevka1204 Nerd Font Mono",
    "buffer_font_features": {
        "calt": true,
        "liga": true,
        "dlig": true,
    },
    "code_lens": "on",
    "diagnostics": {
        "inline": {
            "enabled": true,
        },
    },
    "project_panel": {
        "dock": "left",
    },
    "outline_panel": {
        "dock": "left",
    },
    "collaboration_panel": {
        "dock": "left",
    },
    "git_panel": {
        "dock": "left",
    },
    "ui_font_weight": 400.0,
    "vim_mode": true,
    "terminal": {
        "font_family": ".ZedMono",
        "font_size": 16.0,
        "blinking": "on",
    },
    "telemetry": {
        "diagnostics": true,
        "metrics": true,
    },
    "base_keymap": "VSCode",
    "agent": {
        "dock": "right",
        "enabled": false,
        "button": false,
        "model_parameters": [],
    },
    "relative_line_numbers": "enabled",
    "vertical_scroll_margin": 5.0,
    "gutter": {
        "line_numbers": true,
    },
    "minimap": {
        "show": "auto",
        "thumb": "always",
    },
    "cursor_blink": true,
    "file_types": {},
    "show_whitespaces": "trailing",
    "hard_tabs": false,
    "tab_size": 4,
    "icon_theme": {
        "mode": "dark",
        "light": "Zed (Default)",
        "dark": "Zed (Default)",
    },
    "ui_font_size": 18.0,
    "buffer_font_size": 19.0,
    "theme": {
        "mode": "dark",
        "light": "One Light",
        "dark": "Catppuccin Mocha",
    },
}
