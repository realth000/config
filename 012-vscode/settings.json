{
  "settingsSync.ignoredSettings": [
    "editor.fontFamily",
    "editor.fontSize",
    "editor.fontWeight"
  ],
  "workbench.startupEditor": "newUntitledFile",
  "explorer.confirmDelete": false,
  "security.workspace.trust.untrustedFiles": "open",
  "notebook.cellToolbarLocation": {
    "default": "right",
    "jupyter-notebook": "left"
  },
  "editor.fontFamily": "'GeistMono Nerd Font Mono',  'Iosevka1204 Nerd Font Mono', 'Lilex Nerd Font Mono',  'RecMonoLinear Nerd Font', 'Sarasa Mono SC'",
  "editor.fontWeight": "normal",
  "editor.fontSize": 19,
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "editor.insertSpaces": true,
  "editor.tabSize": 4,
  "terminal.integrated.fontSize": 16,
  "scm.inputFontSize": 20,
  "editor.fontLigatures": true,
  "go.toolsManagement.autoUpdate": true,
  "oneDarkPro.bold": true,
  "oneDarkPro.vivid": true,
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.rulers": [
      80
    ],
    "editor.selectionHighlight": false,
    "editor.suggest.snippetsPreventQuickSuggestions": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": "off",
    "editor.inlayHints.enabled": "offUnlessPressed"
  },
  "editor.minimap.showSlider": "always",
  "cmake.configureOnOpen": true,
  "vim.useCtrlKeys": true,
  "vim.mouseSelectionGoesIntoVisualMode": false,
  "vim.autoindent": true,
  "vim.hlsearch": true,
  "vim.incsearch": true,
  "vim.useSystemClipboard": true,
  "vim.smartcase": true,
  "editor.lineNumbers": "relative",
  "editor.cursorSurroundingLines": 5,
  "editor.renderWhitespace": "trailing",
  "go.useLanguageServer": true,
  "[go]": {
    "editor.snippetSuggestions": "none",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "explicit"
    }
  },
  "gopls": {
    "usePlaceholders": true, // add parameter placeholders when completing a function
    "completionDocumentation": true // for documentation in completion items
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format"
  },
  "window.restoreWindows": "none",
  "editor.formatOnSave": true,
  "vim.vimrc.enable": true,
  "git.openRepositoryInParentFolders": "never",
  "markdownlint.config": {
    "MD033": false,
    "MD024": false
  },
  "haskell.manageHLS": "GHCup",
  "editor.unicodeHighlight.nonBasicASCII": false,
  "vim.vimrc.path": "$HOME/.vimrc",
  "terminal.integrated.cursorBlinking": true,
  "editor.cursorSmoothCaretAnimation": "on",
  "output.smartScroll.enabled": false,
  "editor.stickyScroll.enabled": false,
  "liveServer.settings.donotShowInfoMsg": true,
  "git.autofetch": false,
  "cmake.showOptionsMovedNotification": false,
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": [
        "<space>",
        "c",
        "a"
      ],
      "commands": [
        "editor.action.quickFix"
      ]
    },
    {
      "before": [
        "<space>",
        "r",
        "n"
      ],
      "commands": [
        "editor.action.rename"
      ]
    },
    {
      "before": [
        "\\",
        "f",
        "f"
      ],
      "commands": [
        "workbench.action.quickOpen"
      ]
    },
    {
      "before": [
        "\\",
        "f",
        "g"
      ],
      "commands": [
        "workbench.action.quickTextSearch"
      ]
    },
    {
      "before": [
        "K",
      ],
      "commands": [
        "editor.action.showHover"
      ]
    },
    {
      "before": [
        "[",
        "d"
      ],
      "commands": [
        "editor.action.marker.prev"
      ]
    },
    {
      "before": [
        "]",
        "d"
      ],
      "commands": [
        "editor.action.marker.next"
      ]
    }
  ],
  "indentRainbow.indicatorStyle": "light",
  "indentRainbow.lightIndicatorStyleLineWidth": 1,
  "indentRainbow.colors": [
    "rgba(255,255,64,0.3)",
    "rgba(127,255,127,0.3)",
    "rgba(255,127,255,0.3)",
    "rgba(79,236,236,0.3)"
  ],
  "indentRainbow.errorColor": "",
  "[markdown]": {
    "editor.defaultFormatter": "DavidAnson.vscode-markdownlint"
  },
  "dart.lineLength": 120,
  "gitblame.inlineMessageEnabled": true,
  "gitblame.inlineMessageFormat": "Blame ${author.name} (${time.ago}) ${commit.hash_short}",
  "gitblame.statusBarMessageFormat": "${author.name} (${time.ago}) ${commit.hash_short}",
  "rust-analyzer.lens.enable": false,
  "update.mode": "none",
  "settingsSync.ignoredExtensions": [
    "rust-lang.rust-analyzer",
    "github.codespaces"
  ],
  "kotlin.languageServer.enabled": false,
  "kotlin.debugAdapter.enabled": false,
  "chat.agent.enabled": false,
  "telemetry.feedback.enabled": false,
  "chat.promptFiles": false,
  "chat.promptFilesLocations": {
    ".github/prompts": false
  },
  "workbench.editor.empty.hint": "hidden",
  "rust-analyzer.completion.callable.snippets": "add_parentheses",
  "explorer.confirmDragAndDrop": false,
  "extensions.autoUpdate": false,
  "rust-analyzer.inlayHints.typeHints.hideClosureParameter": true,
  "zig.zls.enabled": "on",
  "zig.zls.inlayHintsHideRedundantParamNames": true,
  "typescript.suggest.completeFunctionCalls": true,
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "typescript.inlayHints.functionLikeReturnTypes.enabled": true,
  "typescript.inlayHints.parameterTypes.enabled": true,
  "typescript.inlayHints.enumMemberValues.enabled": true,
  "typescript.inlayHints.variableTypes.enabled": true,
  "biome.suggestInstallingGlobally": false,
  "editor.inlayHints.enabled": "offUnlessPressed",
  "chat.detectParticipant.enabled": false,
  "chat.extensionTools.enabled": false,
  "chat.implicitContext.enabled": {
    "panel": "never"
  },
  "chat.instructionsFilesLocations": {
    ".github/instructions": false
  },
  "chat.mcp.discovery.enabled": {
    "claude-desktop": false,
    "windsurf": false,
    "cursor-global": false,
    "cursor-workspace": false
  },
  "chat.sendElementsToChat.enabled": false,
  "inlineChat.lineNaturalLanguageHint": false,
  "inlineChat.holdToSpeech": false,
  "inlineChat.accessibleDiffView": "off",
  "dart.checkForSdkUpdates": false,
  "zig.zls.enableArgumentPlaceholders": false,
  "zig.zls.warnStyle": true,
  "extensions.ignoreRecommendations": true,
  "chat.mcp.access": "none",
  "chat.disableAIFeatures": true,
  "editor.cursorBlinking": "smooth",
  "vim.cursorStylePerMode.insert": "line",
  "workbench.colorTheme": "Gleam",
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "errorLens.enabled": true,
  "errorLens.enabledDiagnosticLevels": [
    "error",
    "warning",
    "info",
    "hint"
  ],
  "errorLens.gutterIconsEnabled": true,
  "[c]": {
    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd"
  },
  "python.analysis.typeCheckingMode": "standard",
  "python.analysis.packageIndexDepths": [
    {
      "name": "sklearn",
      "depth": 2
    },
    {
      "name": "matplotlib",
      "depth": 2
    },
    {
      "name": "scipy",
      "depth": 2
    },
    {
      "name": "django",
      "depth": 2
    },
    {
      "name": "flask",
      "depth": 2
    },
    {
      "name": "fastapi",
      "depth": 2
    },
    {
      "name": "cuda",
      "depth": 3,
      "includeAllSymbols": true
    }
  ],
  "clangd.arguments": [
    "--clang-tidy",
    "--function-arg-placeholders=false",
    "--header-insertion=never"
  ],
  "C_Cpp.clang_format_fallbackStyle": "LLVM",
  "C_Cpp.formatting": "vcFormat",
  "window.title": "${activeEditorMedium}${separator}",
  "files.associations": {
    "*.toml": "toml"
  },
  "cmake.showConfigureWithDebuggerNotification": false,
  "window.commandCenter": false,
  "chat.commandCenter.enabled": false,
}